{
  "name": "deltahedges-backend",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:api",
    "start": "node apps/api/dist/index.js",
    "start:api": "node apps/api/dist/index.js",
    "start:worker": "node apps/worker/dist/index.js",
    "dev:api": "npm run dev -w @deltahedge/api",
    "dev:worker": "npm run dev -w @deltahedge/worker",
    "build:shared": "npm run build -w @deltahedge/shared",
    "build:api": "npm run build -w @deltahedge/shared && npm run build -w @deltahedge/api",
    "build:worker": "npm run build -w @deltahedge/shared && npm run build -w @deltahedge/worker",
    "import:proxies": "tsx apps/api/src/scripts/import-proxy-file.ts",
    "assign:proxy": "tsx apps/api/src/scripts/assign-proxy-user.ts",
    "typecheck": "tsc -b packages/shared apps/api apps/worker",
    "test": "tsx --test packages/shared/src/**/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
